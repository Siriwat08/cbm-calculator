# Edge Config for oil price storage (required for oil price feature)
EDGE_CONFIG_ID=your_edge_config_id_here
VERCEL_API_TOKEN=your_vercel_api_token_here

# Admin API Key for protecting write endpoints (POST/DELETE/CRON)
ADMIN_API_KEY=your_admin_api_key_here

# OpenRouteService API Key for distance lookup feature
ORS_API_KEY=your_ors_api_key_here
